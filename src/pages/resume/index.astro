---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroIntro from "../../components/HeroIntro.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { withBase } from "../../lib/paths";
import { resume } from "../../data/resume";
---

<BaseLayout title="Resume | Ashley Klein">
  <HeroIntro
    title={`More about me.`}
    description="Creative experience spanning design, web, video, and marketing."
    actions={[
      { href: withBase("/projects/"), label: "Projects" },
      { href: withBase("/resume/"), label: "Resume", active: true }
    ]}
  />

  <section class="section-rule">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_240px]">
      <div>
        <h2 class="max-w-4xl text-3xl font-bold leading-tight tracking-tight text-text sm:text-4xl">
          {resume.intro}
        </h2>

        <section id="summary" class="mt-10 scroll-mt-24">
          <h3 class="text-xl font-bold text-text">Summary</h3>
          <p class="mt-3 max-w-3xl text-base leading-relaxed text-muted">{resume.summary}</p>
        </section>

        <section id="experience" class="mt-12 scroll-mt-24">
          <h3 class="text-xl font-bold text-text">Experience</h3>
          <div class="mt-6 space-y-8">
            {resume.experience.map((item) => (
              <article class="grid gap-4 border-l border-line pl-5 sm:grid-cols-[180px_minmax(0,1fr)] sm:pl-6">
                <div class="text-sm text-muted">{item.period}</div>
                <div>
                  <h4 class="text-lg font-semibold text-text">{item.title}</h4>
                  <p class="mt-1 text-sm text-soft">{item.company}</p>
                  <ul class="mt-3 space-y-2 text-sm leading-relaxed text-muted">
                    {item.bullets.map((bullet) => <li>{bullet}</li>)}
                  </ul>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="stack" class="mt-12 scroll-mt-24">
          <h3 class="text-xl font-bold text-text">My Stack</h3>
          <div class="mt-5 flex flex-wrap gap-3">
            {resume.stack.map((tool) => (
              <div class="surface-card flex h-14 min-w-14 items-center justify-center px-4" style={`background:${tool.accent}18;border-color:${tool.accent}33;`}>
                <span class="text-base font-bold text-text">{tool.label}</span>
              </div>
            ))}
          </div>
        </section>

        <section id="highlights" class="mt-12 scroll-mt-24">
          <h3 class="text-xl font-bold text-text">Highlights</h3>
          <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {resume.highlights.map((item) => (
              <ProjectCard
                title={item.title}
                categories={[item.category]}
                href={withBase(`/projects/${item.slug}/`)}
              />
            ))}
          </div>
        </section>

        <section id="education" class="mt-12 scroll-mt-24">
          <h3 class="text-xl font-bold text-text">Education</h3>
          <div class="mt-6 space-y-8">
            {resume.education.map((item) => (
              <article class="grid gap-3 sm:grid-cols-[220px_minmax(0,1fr)]">
                <div>
                  <p class="text-sm text-muted">{item.credential}</p>
                  <p class="mt-1 text-lg font-semibold text-text">{item.school}</p>
                </div>
                <ul class="space-y-2 text-sm leading-relaxed text-muted">
                  {item.notes.map((note) => <li>{note}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>
      </div>

      <aside class="surface-card h-fit p-5">
        <p class="eyebrow">Summary</p>
        <nav class="mt-4 space-y-3 text-sm text-muted">
          <a href="#summary" class="block transition hover:text-white">Summary</a>
          <a href="#experience" class="block transition hover:text-white">Experience</a>
          <a href="#stack" class="block transition hover:text-white">My Stack</a>
          <a href="#highlights" class="block transition hover:text-white">Highlights</a>
          <a href="#education" class="block transition hover:text-white">Education</a>
        </nav>
      </aside>
    </div>
  </section>
</BaseLayout>
