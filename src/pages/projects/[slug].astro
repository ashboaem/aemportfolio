---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectSection from "../../components/ProjectSection.astro";
import { withBase } from "../../lib/paths";
import { projects } from "../../data/projects";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const navItems = [
  ["intro", "Introduction"],
  ["challenge", "The Problem"],
  ["work", "The Work"],
  ["solution", "Solution"],
  ["priorities", "Design Priorities"],
  ["role", "My Role"],
  ["lessons", "Lessons Learned"],
  ["showcase", "Showcase"]
];
---

<BaseLayout title={`${project.title} | Ashley Klein`} description={project.summary}>
  <section class="mx-auto max-w-[62rem]">
    <div
      class="media-placeholder aspect-[2.8/1] w-full bg-cover bg-center"
      style={`background-image:linear-gradient(180deg, rgba(0,0,0,0.18), rgba(0,0,0,0.34)), url(${withBase(project.heroImage)});`}
    ></div>
    <h1 class="mt-5 text-[1.75rem] font-bold leading-tight tracking-tight text-text sm:text-[2.15rem]">
      {project.title}
    </h1>
    <div class="mt-3 flex flex-wrap gap-2">
      <a href={withBase("/projects/")} class="pill">
        Projects
      </a>
      <a href={withBase("/resume/")} class="pill">
        Resume
      </a>
    </div>
    <div class="mt-8 border-t border-line pt-3">
      <p class="text-[0.55rem] uppercase tracking-[0.18em] text-muted">
        Projects / {project.title}
      </p>
    </div>
    <div class="mt-7 max-w-3xl">
      <p class="text-3xl font-extrabold leading-[1.02] tracking-tightish text-text sm:text-5xl">
        {project.summary}
      </p>
    </div>
  </section>

  <section class="mx-auto mt-12 max-w-[62rem] lg:grid lg:grid-cols-[minmax(0,44rem)_17rem] lg:gap-8">
    <div class="max-w-[44rem] space-y-10">
      <section id="intro" class="scroll-mt-24">
        <h2 class="text-lg font-semibold tracking-tight text-text sm:text-xl">Introduction</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted sm:text-[0.95rem]">{project.intro}</p>
      </section>
      <ProjectSection id="challenge" title="The Problem" items={project.challenge} />
      <section id="work" class="scroll-mt-24">
        <h2 class="text-lg font-semibold tracking-tight text-text sm:text-xl">The Work</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-3">
          {project.work.map(() => (
            <div class="media-placeholder aspect-[0.86/1] rounded-2xl"></div>
          ))}
        </div>
      </section>
      <ProjectSection id="solution" title="Solution" items={project.solution} />
      <ProjectSection id="priorities" title="Design Priorities" items={project.designPriorities} />
      <ProjectSection id="role" title="My Role" items={project.responsibilities} />
      <ProjectSection id="lessons" title="Lessons Learned" items={project.lessons} />
      <section id="showcase" class="scroll-mt-24">
        <h2 class="text-lg font-semibold tracking-tight text-text sm:text-xl">Showcase</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-3">
          {project.showcaseImages.map(() => (
            <div class="media-placeholder aspect-square rounded-2xl"></div>
          ))}
        </div>
      </section>
    </div>
    <aside class="mt-10 hidden lg:block">
      <nav
        aria-label="Project sections"
        class="sticky top-24 rounded-[2.2rem] bg-[#1c1c1c] px-7 py-10"
      >
        <div class="relative pl-9">
          <div class="absolute left-0 top-[0.15rem] h-[calc(100%-0.3rem)] w-px bg-[#4a4a4a]"></div>
          <div
            class="js-project-nav-indicator absolute -left-px top-0 h-8 w-[3px] rounded-full bg-white transition-[transform,height] duration-200"
          ></div>
          <div class="space-y-5">
            {navItems.map(([id, label], index) => (
              <a
                href={`#${id}`}
                data-project-nav-link
                data-section-id={id}
                class:list={[
                  "block text-[1.02rem] font-semibold leading-none tracking-[-0.02em] text-[#767676] transition-colors duration-200 hover:text-[#f5f5f4]",
                  index === 0 && "is-active text-[#f5f5f4]"
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </div>
      </nav>
    </aside>
  </section>

  <script is:inline>
    const nav = document.querySelector("[aria-label='Project sections']");
    const links = Array.from(document.querySelectorAll("[data-project-nav-link]"));
    const indicator = nav?.querySelector(".js-project-nav-indicator");
    const sections = links
      .map((link) => {
        const id = link.getAttribute("data-section-id");
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean);

    const setActiveLink = (id) => {
      const activeLink = links.find((link) => link.getAttribute("data-section-id") === id);
      if (!activeLink || !indicator) return;

      links.forEach((link) => {
        const isActive = link === activeLink;
        link.classList.toggle("is-active", isActive);
        link.classList.toggle("text-[#f5f5f4]", isActive);
        link.classList.toggle("text-[#767676]", !isActive);
      });

      indicator.style.transform = `translateY(${activeLink.offsetTop}px)`;
      indicator.style.height = `${activeLink.offsetHeight}px`;
    };

    if (links.length && indicator) {
      setActiveLink(links[0].getAttribute("data-section-id"));

      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

          if (visibleEntries[0]?.target?.id) {
            setActiveLink(visibleEntries[0].target.id);
          }
        },
        {
          rootMargin: "-20% 0px -55% 0px",
          threshold: [0.2, 0.4, 0.6]
        }
      );

      sections.forEach((section) => observer.observe(section));
    }
  </script>
</BaseLayout>
