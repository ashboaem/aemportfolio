---
interface Props {
  title: string;
  actionHref?: string;
  actionLabel?: string;
}

const { title, actionHref, actionLabel } = Astro.props;
---

<div class="mb-6 flex items-center justify-between gap-4">
  <h2 class="text-2xl font-bold tracking-tight text-text sm:text-3xl">{title}</h2>
  {
    actionHref && actionLabel && (
      <a href={actionHref} class="pill">
        {actionLabel}
      </a>
    )
  }
</div>
