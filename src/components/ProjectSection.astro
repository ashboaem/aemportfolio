---
interface Props {
  id: string;
  title: string;
  items: string[];
}

const { id, title, items } = Astro.props;
---

<section id={id} class="scroll-mt-24">
  <h2 class="text-lg font-semibold tracking-tight text-text sm:text-xl">{title}</h2>
  <div class="mt-3 space-y-2.5 text-sm leading-relaxed text-muted sm:text-[0.95rem]">
    {items.map((item) => <p>{item}</p>)}
  </div>
</section>
