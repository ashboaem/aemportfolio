---
interface Props {
  id: string;
  title: string;
  items: string[];
}

const { id, title, items } = Astro.props;
---

<section id={id} class="scroll-mt-24">
  <h2 class="text-2xl font-bold tracking-tight text-text">{title}</h2>
  <div class="mt-4 space-y-3 text-base leading-relaxed text-muted">
    {items.map((item) => <p>{item}</p>)}
  </div>
</section>
